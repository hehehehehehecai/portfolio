---
import '../styles/global.css';

const projects = await Astro.glob('../content/projects/*.md');
const sortedProjects = projects.sort((a, b) => {
  const dateA = new Date(a.frontmatter.date);
  const dateB = new Date(b.frontmatter.date);
  return dateB.getTime() - dateA.getTime();
});

// 从文件路径中提取 slug
const getSlugFromPath = (path) => {
  const match = path.match(/projects\/(.*)\.md$/);
  return match ? match[1] : '';
};
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext x='50' y='50' font-size='80' text-anchor='middle' dy='0.3em' font-family='Arial, sans-serif' fill='%23ffffff'%3E🧪%3C/text%3E%3C/svg%3E" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>何晓宇 - Portfolio</title>
		<meta name="description" content="Chemistry Student @ Nankai Univ. | Indie Developer. Developing efficiency tools with code, exploring the world with chemistry." />
	</head>
	<body class="bg-black bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px] text-zinc-300 min-h-screen">
		<main class="container mx-auto px-4 py-8">
			<!-- Hero Section -->
			<section class="text-center mb-16 py-12">
				<!-- 求职状态徽章 -->
				<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm font-medium mb-6 shadow-[0_0_15px_rgba(16,185,129,0.1)]">
					<span class="relative flex h-2.5 w-2.5">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
						<span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
					</span>
					Actively seeking 2026 opportunities
				</div>

				<h1 class="text-4xl font-bold mb-4">何晓宇</h1>
				<h2 class="text-xl text-gray-300 mb-6">Chemistry Student @ Nankai Univ. | Indie Developer</h2>
				<p class="text-zinc-400 max-w-2xl mx-auto mb-10 leading-relaxed text-lg min-h-[4rem] md:min-h-[3rem]">
					<span id="typewriter-text"></span>
					<span class="inline-block w-2 h-5 bg-zinc-400 animate-pulse align-middle ml-1"></span>
				</p>

				<!-- 技能标签墙 -->
				<div class="flex flex-wrap justify-center gap-3 max-w-3xl mx-auto mb-10">
					<span class="px-4 py-2 bg-zinc-900/30 backdrop-blur-md text-zinc-300 rounded-full text-sm font-medium border border-white/10 hover:border-zinc-500/50 hover:text-white transition-all duration-300 cursor-default hover:shadow-[0_0_20px_rgba(161,161,170,0.1)] hover:-translate-y-0.5">React Native (Expo)</span>
					<span class="px-4 py-2 bg-zinc-900/30 backdrop-blur-md text-zinc-300 rounded-full text-sm font-medium border border-white/10 hover:border-zinc-500/50 hover:text-white transition-all duration-300 cursor-default hover:shadow-[0_0_20px_rgba(161,161,170,0.1)] hover:-translate-y-0.5">Astro & Tailwind CSS</span>
					<span class="px-4 py-2 bg-zinc-900/30 backdrop-blur-md text-zinc-300 rounded-full text-sm font-medium border border-white/10 hover:border-zinc-500/50 hover:text-white transition-all duration-300 cursor-default hover:shadow-[0_0_20px_rgba(161,161,170,0.1)] hover:-translate-y-0.5">Supabase (PostgreSQL)</span>
					<span class="px-4 py-2 bg-zinc-900/30 backdrop-blur-md text-zinc-300 rounded-full text-sm font-medium border border-white/10 hover:border-zinc-500/50 hover:text-white transition-all duration-300 cursor-default hover:shadow-[0_0_20px_rgba(161,161,170,0.1)] hover:-translate-y-0.5">Prompt Engineering</span>
					<span class="px-4 py-2 bg-zinc-900/30 backdrop-blur-md text-zinc-300 rounded-full text-sm font-medium border border-white/10 hover:border-zinc-500/50 hover:text-white transition-all duration-300 cursor-default hover:shadow-[0_0_20px_rgba(161,161,170,0.1)] hover:-translate-y-0.5">Python</span>
					<span class="px-4 py-2 bg-zinc-900/30 backdrop-blur-md text-zinc-300 rounded-full text-sm font-medium border border-white/10 hover:border-zinc-500/50 hover:text-white transition-all duration-300 cursor-default hover:shadow-[0_0_20px_rgba(161,161,170,0.1)] hover:-translate-y-0.5">UI/UX Design</span>
					<span class="px-4 py-2 bg-zinc-900/30 backdrop-blur-md text-zinc-300 rounded-full text-sm font-medium border border-white/10 hover:border-zinc-500/50 hover:text-white transition-all duration-300 cursor-default hover:shadow-[0_0_20px_rgba(161,161,170,0.1)] hover:-translate-y-0.5">视频制作与剪辑</span>
				</div>
			</section>
			
			<div class="relative max-w-6xl mx-auto px-4 mb-8">
				<!-- 左箭头按钮 -->
				<button id="prev-btn" class="absolute top-1/2 -translate-y-1/2 -left-6 md:-left-8 w-12 h-12 flex items-center justify-center text-2xl bg-zinc-800 hover:bg-zinc-600 text-white rounded-full z-10 shadow-xl border border-zinc-600 cursor-pointer transition-colors">
					&lt;
				</button>

				<!-- 项目卡片滚动容器 -->
				<div id="project-slider" class="flex items-stretch flex-nowrap overflow-x-auto scroll-smooth snap-x snap-mandatory gap-6 py-4 [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
					{Array.isArray(sortedProjects) && [...sortedProjects, ...sortedProjects, ...sortedProjects].map((project, index) => {
							return (
							<a 
								href={`/projects/${getSlugFromPath(project.file)}`} 
								class="w-[calc((100%-3rem)/3)] flex-shrink-0 snap-start h-full flex flex-col"
							>
								<article class="relative overflow-hidden rounded-xl bg-zinc-900/30 backdrop-blur-md border border-white/10 transition-all duration-300 hover:-translate-y-1 hover:border-zinc-500/50 hover:shadow-[0_0_30px_rgba(161,161,170,0.15)] group h-full flex flex-col justify-between">
									{project.frontmatter.image && (
										<img 
											src={project.frontmatter.image} 
											alt={project.frontmatter.title} 
											class="w-full aspect-video object-cover"
										/>
									)}
									<div class="p-6">
										<h2 class="text-xl font-semibold mb-2">{project.frontmatter.title}</h2>
										<p class="text-gray-300 mb-4 text-sm">{project.frontmatter.description}</p>
										<div class="flex flex-wrap gap-2 mb-4">
											{Array.isArray(project.frontmatter.tags) && project.frontmatter.tags.map((tag) => (
												<span class="px-3 py-1 bg-neutral-700 text-white text-xs font-medium rounded-full">
													{tag}
												</span>
											))}
										</div>
										<div class="flex items-center justify-between text-sm text-gray-400">
											<span>{new Date(project.frontmatter.date).toLocaleDateString()}</span>
											<span class="text-blue-400 hover:underline">查看项目</span>
										</div>
									</div>
								</article>
							</a>
						);
					})}
				</div>

				<!-- 右箭头按钮 -->
				<button id="next-btn" class="absolute top-1/2 -translate-y-1/2 -right-6 md:-right-8 w-12 h-12 flex items-center justify-center text-2xl bg-zinc-800 hover:bg-zinc-600 text-white rounded-full z-10 shadow-xl border border-zinc-600 cursor-pointer transition-colors">
					&gt;
				</button>
			</div>

			<!-- 敏捷进化时间线 -->
			<section class="max-w-3xl mx-auto mt-32 mb-24 px-4">
				<h2 class="text-2xl md:text-3xl font-bold text-white mb-12 text-center tracking-tight">
					Continuous Delivery
				</h2>
				
				<div class="relative border-l border-zinc-700/50 ml-3 md:mx-auto md:w-fit">
					
					<div class="relative pl-8 mb-10 group">
						<div class="absolute w-3 h-3 bg-zinc-500 group-hover:bg-white rounded-full -left-[6.5px] top-1.5 border-2 border-zinc-900 transition-colors"></div>
						<time class="text-sm font-mono text-zinc-500 block mb-1">2026.03</time>
						<h3 class="text-lg font-semibold text-zinc-200 mb-1">双端齐发：跨平台与 AI 结合</h3>
						<p class="text-zinc-400 text-sm leading-relaxed">
							接连上线《平行信箱》与《赛博求签》。突破 Web 端音频与跨平台硬件 API 限制，完成从 Serverless 到本地持久化架构的深度实践。
						</p>
					</div>
					<div class="relative pl-8 mb-10 group">
						<div class="absolute w-3 h-3 bg-zinc-500 group-hover:bg-white rounded-full -left-[6.5px] top-1.5 border-2 border-zinc-900 transition-colors"></div>
						<time class="text-sm font-mono text-zinc-500 block mb-1">2026.02</time>
						<h3 class="text-lg font-semibold text-zinc-200 mb-1">极简转型：个人财务沙盘</h3>
						<p class="text-zinc-400 text-sm leading-relaxed">
							从被拒审中敏捷转型，完成《生存余量 (Runway)》的重构。实现核心计算逻辑，打造极简且直击痛点的财务推演工具。
						</p>
					</div>
					<div class="relative pl-8 mb-10 group">
						<div class="absolute w-3 h-3 bg-zinc-500 group-hover:bg-white rounded-full -left-[6.5px] top-1.5 border-2 border-zinc-900 transition-colors"></div>
						<time class="text-sm font-mono text-zinc-500 block mb-1">2026.01</time>
						<h3 class="text-lg font-semibold text-zinc-200 mb-1">桌面效率：半衰期文件管理</h3>
						<p class="text-zinc-400 text-sm leading-relaxed">
							构建沉浸式桌面工具《流沙中转站》。将“断舍离”哲学与粒子沙丘视觉效果结合，解决桌面文件冗余痛点。
						</p>
					</div>
					<div class="relative pl-8 group">
						<div class="absolute w-3 h-3 bg-zinc-500 group-hover:bg-white rounded-full -left-[6.5px] top-1.5 border-2 border-zinc-900 transition-colors"></div>
						<time class="text-sm font-mono text-zinc-500 block mb-1">2025.12</time>
						<h3 class="text-lg font-semibold text-zinc-200 mb-1">游戏化探索：经济闭环管理</h3>
						<p class="text-zinc-400 text-sm leading-relaxed">
							独立开发《勇者酒馆》。将 RPG 像素风引入时间管理，设计完整的正向激励与经济闭环系统。
						</p>
					</div>
				</div>
			</section>
		</main>
		<footer class="container mx-auto px-4 py-6 border-t border-neutral-800 mt-12">
			<div class="flex flex-col sm:flex-row justify-between items-center gap-4">
				<p class="text-gray-500 text-sm">© 2026 Built with Astro & Trae</p>
				<div class="flex gap-3">
					<a 
						href="https://github.com/hehehehehehecai" 
						target="_blank" 
						rel="noopener noreferrer"
						class="px-4 py-2 bg-neutral-800 text-white rounded-md hover:bg-neutral-700 transition-colors duration-300 font-medium"
					>
						GitHub
					</a>
					<a 
						href="mailto:614517030@qq.com" 
						class="px-4 py-2 bg-neutral-800 text-white rounded-md hover:bg-neutral-700 transition-colors duration-300 font-medium"
					>
						Email Me
					</a>
				</div>
			</div>
		</footer>

		<script is:inline>
			// 滚动控制脚本
			const slider = document.getElementById('project-slider');
			const prevBtn = document.getElementById('prev-btn');
			const nextBtn = document.getElementById('next-btn');

			if (slider && prevBtn && nextBtn) {
				prevBtn.addEventListener('click', () => {
					slider.scrollBy({ left: -350, behavior: 'smooth' });
				});

				nextBtn.addEventListener('click', () => {
					slider.scrollBy({ left: 350, behavior: 'smooth' });
				});
			}
		</script>

		<script is:inline>
			document.addEventListener('DOMContentLoaded', () => {
				const text = "Developing efficiency tools with code, exploring the world with chemistry. Welcome to my digital garden.";
				const speed = 40; // 打字速度 (毫秒)
				let i = 0;
				const target = document.getElementById("typewriter-text");
				
				function typeWriter() {
					if (target && i < text.length) {
						target.innerHTML += text.charAt(i);
						i++;
						setTimeout(typeWriter, speed);
					}
				}
				
				// 延迟 500ms 后开始打字，增加戏剧感
				setTimeout(typeWriter, 500);
			});
		</script>
	</body>
</html>
