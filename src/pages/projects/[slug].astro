---
// 极其关键：告诉 Astro 这是一个静态预渲染页面
export const prerender = true;

import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// 极其关键：必须导出的路由生成函数
export async function getStaticPaths() {
  const projectEntries = await getCollection('projects');
  return projectEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// 获取当前页面的数据和渲染方法
const { entry } = Astro.props;
const { Content } = await entry.render();

// 从 Frontmatter 中获取技术栈和职责数据
const techStack = entry.data.techStack || [];
const myRole = entry.data.roles || [];
---

<Layout title={entry.data.title} description={entry.data.description}>
  <div class="min-h-screen pt-10 relative">
    <!-- 侧边悬浮标签导航 -->
    <div class="fixed left-0 top-1/3 -translate-y-1/2 z-40 hidden md:block">
      <nav class="space-y-4 px-4">
        <a 
          href="#project-background"
          class="block w-28 py-2 px-4 rounded-r-lg backdrop-blur-md bg-white/10 border border-white/20 text-zinc-300 text-sm font-medium transform -translate-x-16 hover:translate-x-0 transition-all duration-300 hover:bg-white/20 hover:text-white"
        >
          项目背景
        </a>
        <a 
          href="#core-tech"
          class="block w-28 py-2 px-4 rounded-r-lg backdrop-blur-md bg-white/10 border border-white/20 text-zinc-300 text-sm font-medium transform -translate-x-16 hover:translate-x-0 transition-all duration-300 hover:bg-white/20 hover:text-white"
        >
          核心技术
        </a>
        <a 
          href="#my-role"
          class="block w-28 py-2 px-4 rounded-r-lg backdrop-blur-md bg-white/10 border border-white/20 text-zinc-300 text-sm font-medium transform -translate-x-16 hover:translate-x-0 transition-all duration-300 hover:bg-white/20 hover:text-white"
        >
          我的职责
        </a>
        <a 
          href="#app-showcase"
          class="block w-28 py-2 px-4 rounded-r-lg backdrop-blur-md bg-white/10 border border-white/20 text-zinc-300 text-sm font-medium transform -translate-x-16 hover:translate-x-0 transition-all duration-300 hover:bg-white/20 hover:text-white"
        >
          实机演示
        </a>
      </nav>
    </div>

    <!-- 主内容区 -->
    <div class="container mx-auto px-4 py-8 md:px-8">
      <!-- 返回首页链接 -->
      <div class="mb-12">
        <a href="/" class="inline-flex items-center text-zinc-300 hover:text-white transition-colors">
          ← 返回首页 (Back to Home)
        </a>
      </div>

      <!-- 顶部全宽标题区 -->
      <section class="mb-12" id="project-background">
        <h1 class="text-5xl md:text-6xl font-bold mb-4 text-zinc-100 leading-tight">{entry.data.title}</h1>
        <p class="text-xl text-zinc-400 mb-8 max-w-3xl">{entry.data.description}</p>
        <div class="h-1 w-24 bg-gradient-to-r from-violet-500 to-indigo-600 rounded-full mb-12"></div>
      </section>

      <!-- 卡片式网格内容区 -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <!-- 左侧宽区 -->
        <div class="md:col-span-2 space-y-12">
          <!-- 设计思路与业务痛点 -->
          <section class="backdrop-blur-sm bg-zinc-900/40 border border-zinc-700/50 rounded-2xl p-8 shadow-lg">
            <h2 class="text-2xl font-semibold text-zinc-100 mb-6" id="core-tech">设计思路与业务痛点</h2>
            <article class="prose prose-invert prose-zinc max-w-none">
              <Content />
            </article>
          </section>

          <!-- 实机演示 -->
          <section class="backdrop-blur-sm bg-zinc-900/40 border border-zinc-700/50 rounded-2xl p-8 shadow-lg" id="app-showcase">
            <h2 class="text-2xl font-semibold text-zinc-100 mb-6">实机演示</h2>
            
            <!-- 灵感公墓展示 -->
            {entry.slug === 'idea-graveyard' && (
              <div class="relative">
                <button id="showcase-prev-btn" class="absolute top-1/2 -translate-y-1/2 -left-4 md:-left-6 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center text-xl md:text-2xl bg-zinc-800/80 hover:bg-zinc-600 text-white rounded-full z-10 shadow-xl border border-zinc-600 cursor-pointer transition-colors">
                  &lt;
                </button>
                
                <div id="showcase-slider" class="flex items-stretch flex-nowrap overflow-x-auto gap-4 snap-x snap-mandatory scroll-smooth py-4 [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
                  {[1, 2, 3, 4, 5, 6].map((i) => (
                    <div class="flex-shrink-0 rounded-xl bg-zinc-900/60 backdrop-blur border border-zinc-700/50 snap-center transition-all duration-300 hover:-translate-y-1 hover:border-zinc-500/50 hover:shadow-[0_0_30px_rgba(161,161,170,0.15)] overflow-hidden">
                      <img 
                        src={`/images/idea-graveyard/idea-graveyard-detail-${i}.png`} 
                        alt={`灵感公墓功能截图 ${i}`} 
                        class="h-80 md:h-96 w-auto max-w-none object-contain rounded-xl" 
                      />
                    </div>
                  ))}
                </div>
                
                <button id="showcase-next-btn" class="absolute top-1/2 -translate-y-1/2 -right-4 md:-right-6 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center text-xl md:text-2xl bg-zinc-800/80 hover:bg-zinc-600 text-white rounded-full z-10 shadow-xl border border-zinc-600 cursor-pointer transition-colors">
                  &gt;
                </button>
              </div>
            )}

            <!-- 平行信箱展示 -->
            {entry.slug === 'parallel-mailbox' && (
              <div class="relative">
                <button id="pm-showcase-prev-btn" class="absolute top-1/2 -translate-y-1/2 -left-4 md:-left-6 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center text-xl md:text-2xl bg-zinc-800/80 hover:bg-zinc-600 text-white rounded-full z-10 shadow-xl border border-zinc-600 cursor-pointer transition-colors">
                  &lt;
                </button>
                
                <div id="pm-showcase-slider" class="flex items-stretch flex-nowrap overflow-x-auto gap-4 snap-x snap-mandatory scroll-smooth py-4 [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
                  {[1, 2, 3, 4, 5].map((i) => (
                    <div class="flex-shrink-0 rounded-xl bg-zinc-900/60 backdrop-blur border border-zinc-700/50 snap-center transition-all duration-300 hover:-translate-y-1 hover:border-zinc-500/50 hover:shadow-[0_0_30px_rgba(161,161,170,0.15)] overflow-hidden">
                      <img 
                        src={`/images/parallel-mailbox/parallel-mailbox${i}.png`} 
                        alt={`平行信箱截图 ${i}`} 
                        class="h-80 md:h-96 w-auto max-w-none object-contain rounded-xl" 
                      />
                    </div>
                  ))}
                </div>
                
                <button id="pm-showcase-next-btn" class="absolute top-1/2 -translate-y-1/2 -right-4 md:-right-6 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center text-xl md:text-2xl bg-zinc-800/80 hover:bg-zinc-600 text-white rounded-full z-10 shadow-xl border border-zinc-600 cursor-pointer transition-colors">
                  &gt;
                </button>
              </div>
            )}

            <!-- 赛博求签展示 -->
            {entry.slug === 'cyber-fortune' && (
              <div class="relative">
                <button id="cf-showcase-prev-btn" class="absolute top-1/2 -translate-y-1/2 -left-4 md:-left-6 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center text-xl md:text-2xl bg-zinc-800/80 hover:bg-zinc-600 text-white rounded-full z-10 shadow-xl border border-zinc-600 cursor-pointer transition-colors">
                  &lt;
                </button>
                
                <div id="cf-showcase-slider" class="flex items-stretch flex-nowrap overflow-x-auto gap-4 snap-x snap-mandatory scroll-smooth py-4 [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
                  {[1, 2, 3, 4].map((i) => (
                    <div class="flex-shrink-0 rounded-xl bg-zinc-900/60 backdrop-blur border border-zinc-700/50 snap-center transition-all duration-300 hover:-translate-y-1 hover:border-zinc-500/50 hover:shadow-[0_0_30px_rgba(161,161,170,0.15)] overflow-hidden">
                      <img 
                        src={`/images/cyber-fortune/cyber-fortune${i}.png`} 
                        alt={`赛博求签截图 ${i}`} 
                        class="h-80 md:h-96 w-auto max-w-none object-contain rounded-xl" 
                      />
                    </div>
                  ))}
                </div>
                
                <button id="cf-showcase-next-btn" class="absolute top-1/2 -translate-y-1/2 -right-4 md:-right-6 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center text-xl md:text-2xl bg-zinc-800/80 hover:bg-zinc-600 text-white rounded-full z-10 shadow-xl border border-zinc-600 cursor-pointer transition-colors">
                  &gt;
                </button>
              </div>
            )}
          </section>
        </div>

        <!-- 右侧窄区 -->
        <div class="space-y-8">
          <!-- 技术栈卡片 -->
          {techStack.length > 0 && (
            <section class="backdrop-blur-sm bg-zinc-900/40 border border-zinc-700/50 rounded-2xl p-6 shadow-lg">
              <h3 class="text-xl font-semibold text-zinc-100 mb-4">技术栈</h3>
              <div class="space-y-2">
                {techStack.map((tech) => (
                  <div class="flex items-center gap-3">
                    <div class="w-2 h-2 rounded-full bg-violet-500"></div>
                    <span class="text-zinc-300 text-sm">{tech}</span>
                  </div>
                ))}
              </div>
            </section>
          )}

          <!-- 我的职责卡片 -->
          {myRole.length > 0 && (
            <section class="backdrop-blur-sm bg-zinc-900/40 border border-zinc-700/50 rounded-2xl p-6 shadow-lg" id="my-role">
              <h3 class="text-xl font-semibold text-zinc-100 mb-4">我的职责</h3>
              <div class="space-y-2">
                {myRole.map((role) => (
                  <div class="flex items-center gap-3">
                    <div class="w-2 h-2 rounded-full bg-indigo-500"></div>
                    <span class="text-zinc-300 text-sm">{role}</span>
                  </div>
                ))}
              </div>
            </section>
          )}

          <!-- 项目信息卡片 -->
          <section class="backdrop-blur-sm bg-zinc-900/40 border border-zinc-700/50 rounded-2xl p-6 shadow-lg">
            <h3 class="text-xl font-semibold text-zinc-100 mb-4">项目信息</h3>
            <div class="space-y-3">
              <div class="flex justify-between">
                <span class="text-zinc-400 text-sm">开发时间</span>
                <span class="text-zinc-300 text-sm font-medium">{entry.data.date}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-zinc-400 text-sm">项目类型</span>
                <span class="text-zinc-300 text-sm font-medium">{entry.data.tags?.[0] || '个人项目'}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-zinc-400 text-sm">技术方向</span>
                <span class="text-zinc-300 text-sm font-medium">全栈开发</span>
              </div>
            </div>
          </section>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  // 应用展示轮播控制脚本
  document.addEventListener('DOMContentLoaded', () => {
    // 灵感公墓轮播
    const showcaseSlider = document.getElementById('showcase-slider');
    const prevBtn = document.getElementById('showcase-prev-btn');
    const nextBtn = document.getElementById('showcase-next-btn');

    if (showcaseSlider && prevBtn && nextBtn) {
      prevBtn.addEventListener('click', () => {
        showcaseSlider.scrollBy({ left: -320, behavior: 'smooth' });
      });

      nextBtn.addEventListener('click', () => {
        showcaseSlider.scrollBy({ left: 320, behavior: 'smooth' });
      });
    }

    // 平行信箱轮播
    const pmSlider = document.getElementById('pm-showcase-slider');
    const pmPrevBtn = document.getElementById('pm-showcase-prev-btn');
    const pmNextBtn = document.getElementById('pm-showcase-next-btn');

    if (pmSlider && pmPrevBtn && pmNextBtn) {
      pmPrevBtn.addEventListener('click', () => {
        pmSlider.scrollBy({ left: -340, behavior: 'smooth' });
      });

      pmNextBtn.addEventListener('click', () => {
        pmSlider.scrollBy({ left: 340, behavior: 'smooth' });
      });
    }

    // 赛博求签轮播
    const cfSlider = document.getElementById('cf-showcase-slider');
    const cfPrevBtn = document.getElementById('cf-showcase-prev-btn');
    const cfNextBtn = document.getElementById('cf-showcase-next-btn');

    if (cfSlider && cfPrevBtn && cfNextBtn) {
      cfPrevBtn.addEventListener('click', () => {
        cfSlider.scrollBy({ left: -340, behavior: 'smooth' });
      });

      cfNextBtn.addEventListener('click', () => {
        cfSlider.scrollBy({ left: 340, behavior: 'smooth' });
      });
    }

    // 侧边导航滚动效果
    const navLinks = document.querySelectorAll('nav a');
    const sections = document.querySelectorAll('section[id]');

    window.addEventListener('scroll', () => {
      let current = '';
      
      sections.forEach(section => {
        const sectionTop = section.offsetTop;
        const sectionHeight = section.clientHeight;
        if (pageYOffset >= sectionTop - 200) {
          current = section.getAttribute('id') || '';
        }
      });

      navLinks.forEach(link => {
        link.classList.remove('bg-white/20', 'text-white');
        link.classList.add('bg-white/10', 'text-zinc-300');
        if (link.getAttribute('href') === `#${current}`) {
          link.classList.remove('bg-white/10', 'text-zinc-300');
          link.classList.add('bg-white/20', 'text-white');
          link.style.transform = 'translateX(0)';
        } else {
          link.style.transform = 'translateX(-16px)';
        }
      });
    });
  });
</script>
